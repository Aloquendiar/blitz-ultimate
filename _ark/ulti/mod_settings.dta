{new UIScreen
   mod_hud_settings_screen
   (panels mod_hud_settings_panel)
   (focus mod_hud_settings_panel)
   (back mod_visual_settings_screen)
}
{new UIPanel
   mod_force_plot_panel
   SETTINGS_LIST_FILE
   (title os_force_plot)
   (data (
      off
      ;plot_airport
      plot_bodega_a
      plot_bodegapartment_a
      ;plot_bridge
      plot_brownstone_a
      plot_brownstone_b
      ;plot_brownstone_c
      plot_bus_used_car
      plot_firehouse_townhall
      plot_gasstation_a
      plot_hotel_a
      ;plot_outro_blitz
      ;plot_park
      plot_quickmart_a
      ;plot_river
      plot_stores_a
      plot_subway_a
      plot_subwaylong_a
      ;plot_subway_bridge
      plot_theater_a
      plot_tokyo_a
      plot_tokyo_b
      plot_tokyo_c
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG {os_down_common})
   (SELECT_MSG
      {set $forceplot
         {if_else {$component selected_pos}
            {$component selected_sym}
            FALSE
         }
      }
      {pop_and_goto_screen mod_visual_settings_screen}
   )
}
{new UIScreen
   mod_force_plot_screen
   (panels mod_force_plot_panel)
   (focus mod_force_plot_panel)
   (back mod_visual_settings_screen)
}
{new UIPanel
   mod_force_skybox_panel
   SETTINGS_LIST_FILE
   (title os_force_skybox)
   (data (
      default_skybox
      no_skybox
      nfs_mw2012
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG {os_down_common})
   (SELECT_MSG
      {set $which_skybox {$component selected_pos}}
      {pop_and_goto_screen mod_visual_settings_screen}
   )
}
{new UIScreen
   mod_force_skybox_screen
   (panels mod_force_skybox_panel)
   (focus mod_force_skybox_panel)
   (back mod_visual_settings_screen)
}
{new UIPanel
   mod_other_settings_panel
   SETTINGS_LIST_FILE
   (title mod_other)
   (data (
      (os_unlock_all
         (type uOnOFF)
         (bool $unlockall)
         (reboot TRUE)
         (sel_script {toggle_var unlockall})
      )
      #ifdef HX_PS3
      (os_server_url
         (type uOnOFF)
         (bool $server_url)
         (reboot TRUE)
         (sel_script
            {virtual_keyboard show_keyboard
               $user
               50
               {localize server_url}
               {localize server_url}
               {if_else $server_url $server_url "ps3-blitz-live.hmxservices.com"}
               $this
            }
         )
      )
      (os_server_ssl
         (type uOnOFF)
         (bool $server_ssl)
         (reboot TRUE)
         (sel_script {toggle_var server_ssl})
      )
      (os_p9dlc
         (type uOnOFF)
         (bool $p9dlc)
         (reboot TRUE)
         (sel_script {toggle_var p9dlc})
      )
      #endif
      (os_online_acc
         (type uNormal)
         (sel_script
            {foreach $acc
               (
                  acc_high_cred
                  acc_higher_cred
                  acc_total_coins_spent
                  acc_create_challenge
               )
               {acc_mgr earn_accomplishment $acc}
            }
         )
      )
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG {os_down_common})
   (SELECT_MSG {os_sel_common})
   (VIRTUAL_KEYBOARD_RESULT_MSG
      {if {&& $ok $this}
         {set $server_url $text}
      }
      {lst_reset}
   )
}
{new UIScreen
   mod_other_settings_screen
   (panels mod_other_settings_panel)
   (focus mod_other_settings_panel)
   (back mod_settings_screen)
}