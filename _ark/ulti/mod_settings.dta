{new UIPanel
   mod_warning_panel
   (file "../ui/error/error_general.milo")
   (enter
      {$this set_showing FALSE}
      {all.grp set_showing TRUE}
      {error.lbl set_token_fmt reboot_warning}
   )
   (BUTTON_DOWN_MSG
      {if {== $action kAction_Confirm}
         {mod_settings_panel handle_leave}
      }
   )
}
{new UIPanel
   mod_settings_panel
   SETTINGS_LIST_FILE
   (should_warn)
   (title mod_settings)
   (data (
      (mod_game
         (type uNormal)
         (sel_script {pop_and_goto_screen mod_game_settings_screen})
      )
      (mod_visual
         (type uNormal)
         (sel_script {pop_and_goto_screen mod_visual_settings_screen})
      )
      (mod_other
         (type uNormal)
         (sel_script {pop_and_goto_screen mod_other_settings_screen})
      )
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG
      {if {find_elem (kAction_Cancel kAction_ViewModify) $action}
         #ifndef HX_3DS
         {ulti_settings_writer}
         #endif
         {if_else [should_warn]
            {do
               {$this set_showing FALSE}
               {mod_warning_panel set_showing TRUE}
               {mod_settings_screen set_focus_panel mod_warning_panel}
               {set [should_warn] FALSE}
            }
            {do
               {set [pos] (0 0)}
               {$this handle_leave}
            }
         }
      }
      kDataUnhandled
   )
   (SELECT_MSG {os_sel_common})
   (handle_leave
      {ui pop_screen}
      {if {pause_panel is_up}
         {pause_panel set_showing TRUE}
      }
   )
}
{new UIScreen
   mod_settings_screen
   (enter
      {mod_settings_panel set_showing TRUE}
      {mod_warning_panel set_showing FALSE}
      {$this set_focus_panel mod_settings_panel}
   )
   (panels mod_settings_panel mod_warning_panel)
}
{new UIPanel
   mod_game_settings_panel
   SETTINGS_LIST_FILE
   (title mod_game)
   (data (
      (os_precision
         (type uOnOFF)
         (bool $freq_ms)
         (sel_script {toggle_var freq_ms})
      )
      (os_disable_rw
         (type uOnOFF)
         (bool $disable_random_wiggles)
         (sel_script {toggle_var disable_random_wiggles})
      )
      (os_cameraangle
         (type uSld)
         (fmt_type uAngle)
         (var camera_angle)
         (step 1)
         (range 0 2)
      )
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG {os_down_common})
   (SELECT_MSG {os_sel_common})
}
{new UIScreen
   mod_game_settings_screen
   (panels mod_game_settings_panel)
   (focus mod_game_settings_panel)
   (back mod_settings_screen)
}
{new UIPanel
   mod_visual_settings_panel
   SETTINGS_LIST_FILE
   (title mod_visual)
   (data (
      (os_disable_dof
         (type uOnOFF)
         (bool $disable_dof)
         (sel_script {toggle_var disable_dof})
      )
      (os_letterbox
         (type uOnOFF)
         (bool $letterbox)
         (sel_script {toggle_var letterbox})
      )
      (os_hud_settings
         (type uNormal)
         (sel_script {pop_and_goto_screen mod_hud_settings_screen})
      )
      (os_disable_plots
         (type uOnOFF)
         (bool $disable_plots)
         (reboot TRUE)
         (sel_script {toggle_var disable_plots})
      )
      (os_force_plot
         (type uOnOFF)
         (bool $forceplot)
         (reboot TRUE)
         (sel_script {pop_and_goto_screen mod_force_plot_screen})
      )
      (os_force_skybox
         (type uOnOFF)
         (bool $which_skybox)
         (reboot TRUE)
         (sel_script {pop_and_goto_screen mod_force_skybox_screen})
      )
   ))
   (enter {os_setup_common})
   (BUTTON_DOWN_MSG {os_down_common})
   (SELECT_MSG {os_sel_common})
}
{new UIScreen
   mod_visual_settings_screen
   (panels mod_visual_settings_panel)
   (focus mod_visual_settings_panel)
   (back mod_settings_screen)
}
